{
	"schemaVersion": 1,
	"id": "niagara",
	"version": "${version}",
	"name": "Niagara",
	"description": "A lightweight UI library that renders HTML/CSS interfaces using Ultralight, enabling modern web-based UIs.",
	"authors": [
		"Ayydxn"
	],
	"contact": {
		"sources": "https://github.com/Solomon-Team/Niagara",
		"issues": "https://github.com/Solomon-Team/Niagara/issues"
	},
	"license": "LGPL-3.0-or-later",
	"icon": "assets/niagara/icon.png",
	"environment": "*",
	"entrypoints": {
		"preLaunch": [
			"me.ayydxn.niagara.NiagaraPreLaunchEntrypoint"
		],
		"client": [
			"me.ayydxn.niagara.NiagaraClientMod"
		]
	},
	"mixins": [
		"niagara.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
